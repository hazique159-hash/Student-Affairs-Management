
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    function isStudent() {
        // A user is a student if they are not an admin or a teacher.
        // This relies on the fact that all users are one of the three roles.
        return isSignedIn() && !isAdmin() && !isTeacher();
    }
    
    // Get the student document ID associated with the current user's auth UID
    function getStudentId() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId;
    }


    // Admin Roles: Only admins can manage the admin role list.
    match /roles_admin/{adminId} {
      allow read, write: if isAdmin();
    }

    // Teachers Collection: Admins manage teachers. Teachers can read their own profile.
    match /teachers/{teacherId} {
      allow create: if isAdmin();
      allow get: if isOwner(teacherId) || isAdmin();
      allow list: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin();
    }
    
    // Students Collection: Admins manage students. Teachers can read student data.
    match /students/{studentId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin();
    }

    // Users Collection: Links auth UIDs to student IDs.
    match /users/{userId} {
      allow create: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
    }

    // Announcements Collection: Publicly readable, admin-writable.
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Complaints Collection: Complex role-based access.
    match /complaints/{complaintId} {
      // Create: Only teachers can create complaints, and they must be the author.
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      
      // Read:
      // 1. Admins can read all complaints.
      // 2. Teachers can only read complaints they have submitted.
      // 3. Students can only read complaints against them if status is 'Approved' or 'Resolved'.
      allow read: if isAdmin() ||
                   (isTeacher() && resource.data.teacherId == request.auth.uid) ||
                   (isStudent() && resource.data.studentId == getStudentId() && (resource.data.status == 'Approved' || resource.data.status == 'Resolved'));
                   
      // Update: Only admins can update complaints (e.g., change status).
      allow update: if isAdmin();
      
      // Delete: Only admins can delete complaints.
      allow delete: if isAdmin();
    }
    
    // Student-specific Subcollections
    match /users/{userId}/counselingSessions/{counselingSessionId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    match /users/{userId}/fines/{fineId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }
  }
}
