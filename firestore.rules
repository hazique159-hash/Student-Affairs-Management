
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // Admin Roles: Only admins can manage the admin role list.
    match /roles_admin/{adminId} {
      allow read, write: if isAdmin();
    }

    // Teachers Collection: Admins manage teachers. Teachers can read their own profile.
    match /teachers/{teacherId} {
      allow create: if isAdmin();
      allow get: if isOwner(teacherId) || isAdmin();
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    // Students Collection: Admins manage students. Teachers can read student data.
    match /students/{studentId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin();
    }

    // Users Collection: Links auth UIDs to student IDs.
    match /users/{userId} {
      allow create: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
    }

    // Announcements Collection: Publicly readable, admin-writable.
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Complaints Collection: Admins can read all. Students/Teachers can create. Admins can update status.
    match /complaints/{complaintId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn(); // Students and Teachers can create complaints
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Student-specific Subcollections
    match /users/{userId}/counselingSessions/{counselingSessionId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    match /users/{userId}/fines/{fineId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    match /users/{userId}/complaints/{complaintId} {
        allow read: if isOwner(userId) || isTeacher() || isAdmin();
        // Admin can create a complaint in a student's subcollection upon approval
        allow create: if isOwner(userId) || isTeacher() || isAdmin();
        allow update: if isAdmin(); // Admin can update status
        allow delete: if isAdmin();
    }
  }
}
