
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "studentaffairs316@gmail.com" ||
        (request.auth.token.email != null && request.auth.token.email.endsWith("@admin.com"))
      );
    }

    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    match /roles_admin/{adminId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow create: if isAdmin();
      allow get: if isOwner(teacherId) || isAdmin();
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /students/{studentId} {
      allow create: if isAdmin();
      allow get: if isSignedIn();
      allow list: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isAdmin() || isOwner(userId);
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow update: if isOwner(userId) || isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /complaints/{complaintId} {
      allow get, list, delete: if isAdmin();
      allow create: if isSignedIn();
      // Allow students to update payment info on their own violations
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentReceiptUrl']));
    }

    match /fines/{fineId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /counseling_availability/{availabilityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /{path=**}/counselingSessions/{counselingSessionId} {
      allow get, list: if isAdmin();
    }

    match /users/{userId}/counselingSessions/{counselingSessionId} {
      allow read, write: if isAdmin() || isOwner(userId);
    }

    match /users/{userId}/complaints/{complaintId} {
        allow read: if isOwner(userId) || isTeacher() || isAdmin();
        allow create: if isOwner(userId) || isTeacher() || isAdmin();
        allow update: if isAdmin() || isOwner(userId);
        allow delete: if isAdmin();
    }
    
    match /volunteerApplications/{applicationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId}/volunteerApplications/{applicationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin() || isOwner(userId);
    }
  }
}
