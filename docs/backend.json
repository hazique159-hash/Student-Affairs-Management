
{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Student entity."
        },
        "registrationNumber": {
          "type": "string",
          "description": "Student's registration number (e.g., BCS223089)."
        },
        "firstName": {
          "type": "string",
          "description": "Student's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Student's last name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Student's contact phone number."
        },
        "department": {
          "type": "string",
          "description": "Student's department (e.g., CS, SE, BBA)."
        },
        "parentEmail": {
          "type": "string",
          "description": "Parent's email address for notifications.",
          "format": "email"
        },
        "parentPhoneNumber": {
          "type": "string",
          "description": "Parent's phone number for SMS and WhatsApp notifications."
        },
        "recoveryEmail": {
          "type": "string",
          "description": "Personal email address for password recovery.",
          "format": "email"
        },
        "complaintCount": {
          "type": "number",
          "description": "The number of approved complaints against the student."
        }
      },
      "required": [
        "id",
        "registrationNumber",
        "firstName",
        "lastName",
        "department"
      ]
    },
    "Announcement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Announcement",
      "type": "object",
      "description": "Represents a public announcement for students.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Announcement entity."
        },
        "title": {
          "type": "string",
          "description": "Title of the announcement."
        },
        "content": {
          "type": "string",
          "description": "Content of the announcement."
        },
        "datePublished": {
          "type": "string",
          "description": "Date the announcement was published.",
          "format": "date-time"
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional image URL for the announcement.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "title",
        "content",
        "datePublished"
      ]
    },
    "Teacher": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Teacher entity."
        },
        "firstName": {
          "type": "string",
          "description": "Teacher's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Teacher's last name."
        },
        "email": {
          "type": "string",
          "description": "Teacher's email address.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "Teacher's contact phone number."
        },
        "department": {
          "type": "string",
          "description": "Teacher's department (e.g., CS, SE, BBA)."
        },
        "recoveryEmail": {
          "type": "string",
          "description": "Personal email address for password recovery.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "department"
      ]
    },
    "CounselingSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CounselingSession",
      "type": "object",
      "description": "Represents a counseling session scheduled for a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the CounselingSession entity."
        },
        "studentId": {
          "type": "string",
          "description": "Reference to Student. (Relationship: Student 1:N CounselingSession)"
        },
        "studentName": {
          "type": "string",
          "description": "Name of the student for display purposes."
        },
        "teacherId": {
          "type": "string",
          "description": "ID of the teacher for the session."
        },
        "teacherName": {
          "type": "string",
          "description": "Name of the teacher for display purposes."
        },
        "dateScheduled": {
          "type": "string",
          "description": "Date and time of the counseling session.",
          "format": "date-time"
        },
        "timeSlot": {
          "type": "string",
          "description": "The scheduled time slot."
        },
        "notes": {
          "type": "string",
          "description": "Notes from the counseling session."
        }
      },
      "required": [
        "id",
        "studentId",
        "studentName",
        "teacherId",
        "teacherName",
        "dateScheduled",
        "timeSlot"
      ]
    },
    "Fine": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Fine",
      "type": "object",
      "description": "Represents a fine issued to a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Fine entity."
        },
        "studentId": {
          "type": "string",
          "description": "Registration number of the student."
        },
        "amount": {
          "type": "number",
          "description": "Amount of the fine."
        },
        "reason": {
          "type": "string",
          "description": "Reason for the fine."
        },
        "dateIssued": {
          "type": "string",
          "description": "Date the fine was issued.",
          "format": "date-time"
        },
        "dateDue": {
          "type": "string",
          "description": "Date the fine is due.",
          "format": "date-time"
        },
        "isPaid": {
          "type": "boolean",
          "description": "Indicates whether the fine has been paid."
        }
      },
      "required": [
        "id",
        "studentId",
        "amount",
        "reason",
        "dateIssued",
        "dateDue",
        "isPaid"
      ]
    },
    "Admin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Admin",
      "type": "object",
      "description": "Represents an administrator in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Admin entity."
        },
        "username": {
          "type": "string",
          "description": "Admin's username for login."
        },
        "email": {
          "type": "string",
          "description": "Admin's email address.",
          "format": "email"
        },
        "recoveryEmail": {
          "type": "string",
          "description": "Personal email address for password recovery.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "username",
        "email"
      ]
    },
    "Complaint": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Complaint",
      "type": "object",
      "description": "Represents a complaint filed about a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Complaint entity."
        },
        "studentId": {
          "type": "string",
          "description": "Reference to the student the complaint is about."
        },
        "studentName": {
          "type": "string",
          "description": "Name of the student the complaint is about."
        },
        "filedById": {
          "type": "string",
          "description": "The Auth UID of the user who filed the complaint."
        },
        "filedByName": {
          "type": "string",
          "description": "The name of the user who filed the complaint."
        },
        "title": {
          "type": "string",
          "description": "Title of the complaint."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the complaint."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending",
            "Open",
            "Approved",
            "Rejected",
            "Resolved"
          ],
          "description": "Current status of the complaint."
        },
        "dateSubmitted": {
          "type": "string",
          "description": "Date the complaint was submitted.",
          "format": "date-time"
        },
        "evidenceUrl": {
          "type": "string",
          "description": "Optional data URI for image or video evidence.",
          "format": "uri"
        }
      },
      "required": [
        "studentId",
        "studentName",
        "filedById",
        "filedByName",
        "title",
        "description",
        "status",
        "dateSubmitted"
      ]
    },
    "TeacherAvailability": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TeacherAvailability",
      "type": "object",
      "description": "Defines a teacher's available days and time slots for counseling.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the availability entry."
        },
        "teacherId": {
          "type": "string",
          "description": "Reference to the Teacher entity."
        },
        "teacherName": {
          "type": "string",
          "description": "Full name of the teacher."
        },
        "availableDays": {
          "type": "array",
          "description": "Days of the week the teacher is available.",
          "items": {
            "type": "string",
            "enum": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ]
          }
        },
        "availableSlots": {
          "type": "array",
          "description": "Time slots the teacher is available.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "teacherId",
        "teacherName",
        "availableDays",
        "availableSlots"
      ]
    },
    "VolunteerApplication": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "VolunteerApplication",
      "type": "object",
      "description": "Represents a student's application to volunteer for an event.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the VolunteerApplication entity."
        },
        "studentId": {
          "type": "string",
          "description": "The registration number of the student applying."
        },
        "studentName": {
          "type": "string",
          "description": "The name of the student applying."
        },
        "department": {
          "type": "string",
          "description": "The department of the student."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The contact number of the student."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "The WhatsApp number of the student."
        },
        "semester": {
          "type": "string",
          "description": "The current semester of the student."
        },
        "eventName": {
          "type": "string",
          "description": "The name of the event the student is volunteering for."
        },
        "reason": {
          "type": "string",
          "description": "The student's reason for wanting to volunteer."
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending",
            "Approved",
            "Rejected"
          ],
          "description": "The current status of the application."
        },
        "dateApplied": {
          "type": "string",
          "format": "date-time",
          "description": "The date the application was submitted."
        }
      },
      "required": [
        "id",
        "studentId",
        "studentName",
        "eventName",
        "reason",
        "status",
        "dateApplied",
        "whatsappNumber",
        "semester"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "Admin",
          "schema": {
            "$ref": "#/backend/entities/Admin"
          },
          "description": "Collection to store admin roles.",
          "params": [
            {
              "name": "adminId",
              "description": "The Firebase Auth UID of the admin user."
            }
          ]
        }
      },
      {
        "path": "/teachers/{teacherId}",
        "definition": {
          "entityName": "Teacher",
          "schema": {
            "$ref": "#/backend/entities/Teacher"
          },
          "description": "Collection to store teacher data.",
          "params": [
            {
              "name": "teacherId",
              "description": "The unique ID of the teacher."
            }
          ]
        }
      },
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": {
            "$ref": "#/backend/entities/Student"
          },
          "description": "Collection to store student data.",
          "params": [
            {
              "name": "studentId",
              "description": "The registration number of the student."
            }
          ]
        }
      },
      {
        "path": "/announcements/{announcementId}",
        "definition": {
          "entityName": "Announcement",
          "schema": {
            "$ref": "#/backend/entities/Announcement"
          },
          "description": "Collection to store public announcements.",
          "params": [
            {
              "name": "announcementId",
              "description": "The unique ID of the announcement."
            }
          ]
        }
      },
      {
        "path": "/complaints/{complaintId}",
        "definition": {
          "entityName": "Complaint",
          "schema": {
            "$ref": "#/backend/entities/Complaint"
          },
          "description": "Top-level collection for all complaints.",
          "params": [
            {
              "name": "complaintId",
              "description": "The unique ID of the complaint."
            }
          ]
        }
      },
      {
        "path": "/fines/{fineId}",
        "definition": {
          "entityName": "Fine",
          "schema": {
            "$ref": "#/backend/entities/Fine"
          },
          "description": "Top-level collection for all fines, issued by registration number.",
          "params": [
            {
              "name": "fineId",
              "description": "The unique ID of the fine."
            }
          ]
        }
      },
      {
        "path": "/counseling_availability/{availabilityId}",
        "definition": {
          "entityName": "TeacherAvailability",
          "schema": {
            "$ref": "#/backend/entities/TeacherAvailability"
          },
          "description": "Collection to store teacher availability for counseling sessions.",
          "params": [
            {
              "name": "availabilityId",
              "description": "The unique ID of the availability entry."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/counselingSessions/{counselingSessionId}",
        "definition": {
          "entityName": "CounselingSession",
          "schema": {
            "$ref": "#/backend/entities/CounselingSession"
          },
          "description": "Subcollection to store counseling sessions scheduled for each student.",
          "params": [
            {
              "name": "userId",
              "description": "The user ID (student UID) of the student."
            },
            {
              "name": "counselingSessionId",
              "description": "The unique ID of the counseling session."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/complaints/{complaintId}",
        "definition": {
          "entityName": "Complaint",
          "schema": {
            "$ref": "#/backend/entities/Complaint"
          },
          "description": "Subcollection to store personal complaint history.",
          "params": [
            {
              "name": "userId",
              "description": "The Auth UID of the user."
            },
            {
              "name": "complaintId",
              "description": "The unique ID of the complaint."
            }
          ]
        }
      },
      {
        "path": "/volunteerApplications/{applicationId}",
        "definition": {
          "entityName": "VolunteerApplication",
          "schema": {
            "$ref": "#/backend/entities/VolunteerApplication"
          },
          "description": "Top-level collection for all volunteer applications.",
          "params": [
            {
              "name": "applicationId",
              "description": "The unique ID of the application."
            }
          ]
        }
      }
    ]
  }
}
